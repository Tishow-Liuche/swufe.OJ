{
  "manifest_version": 3,
  "name": "OJ Remote Submit Helper",
  "version": "0.9.1",
  "description": "CF 远程提交 — 全自动 Content Script",
  "host_permissions": [
    "https://codeforces.com/*",
    "http://127.0.0.1:3000/*",
    "http://localhost:3000/*"
  ],
  "content_scripts": [{
    "matches": [
      "http://127.0.0.1:3000/*",
      "http://localhost:3000/*"
    ],
    "js": ["content.js"],
    "run_at": "document_start"
  }]
}
