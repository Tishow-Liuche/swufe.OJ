{
  "manifest_version": 3,
  "name": "OJ Remote Submit Helper",
  "version": "0.5.0",
  "description": "CF 远程提交助手",
  "permissions": ["storage", "scripting", "alarms"],
  "host_permissions": [
    "https://codeforces.com/*",
    "http://127.0.0.1:3000/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_title": "OJ Helper" }
}
