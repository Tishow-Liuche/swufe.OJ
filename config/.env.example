# ========== 数据库 ==========
DATABASE_URL="postgresql://oj:replace-with-postgres-password@localhost:5432/oj_platform"

# ========== Redis ==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=replace-with-the-same-redis-password-as-config-infra-env

# ========== JWT ==========
JWT_ACCESS_SECRET=change-me-to-a-random-64-char-string
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ========== MinIO / S3 ==========
S3_ENDPOINT=localhost
S3_PORT=9000
S3_ACCESS_KEY=replace-with-the-same-minio-user-as-config-infra-env
S3_SECRET_KEY=replace-with-the-same-minio-password-as-config-infra-env
S3_BUCKET=oj-testdata
S3_USE_SSL=false

# ========== go-judge ==========
GO_JUDGE_URL=http://localhost:5050
GO_JUDGE_AUTH_TOKEN=

# ========== 洛谷开放平台 ==========
# 在 https://docs.lgapi.cn/open/ 注册 OpenApp 获取 Token
# 格式: username:password
LUOGU_OPENAPP_TOKEN=

# ========== AtCoder 只读元数据 ==========
# 当前只允许低频读取公开题目元数据；自动提交始终关闭
VJUDGE_ATCODER_ENABLED=true
# 预留配置位；当前实现无论此值为何都不会执行自动提交
VJUDGE_ATCODER_ALLOW_AUTO_SUBMIT=false
VJUDGE_ATCODER_METADATA_INTERVAL_MS=2000
VJUDGE_ATCODER_HTTP_TIMEOUT_MS=15000
VJUDGE_ATCODER_USER_AGENT=swufe-oj-readonly-metadata/1.0

# ========== 应用 ==========
APP_PORT=3000
APP_HOST=localhost
NODE_ENV=development
COOKIE_SECURE=false
TRUST_PROXY=false

# ========== Sentry (可选) ==========
SENTRY_DSN=
