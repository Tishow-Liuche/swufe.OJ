# Docker 基础设施变量。复制为 config/infra.env 后替换所有占位符，切勿提交真实文件。
POSTGRES_USER=oj
POSTGRES_PASSWORD=replace-with-a-random-32-char-postgres-password
POSTGRES_DB=oj_platform
REDIS_PASSWORD=replace-with-a-random-32-char-redis-password
MINIO_ROOT_USER=replace-with-a-non-default-minio-user
MINIO_ROOT_PASSWORD=replace-with-a-random-32-char-minio-password
