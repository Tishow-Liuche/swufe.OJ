generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================== 用户与权限 =====================

model User {
  id                       String   @id @default(cuid())
  username                 String   @unique
  email                    String   @unique
  password                 String
  nickname                 String?
  avatar                   String?
  studentId                String?  @unique
  college                  String?
  phone                    String?
  mustChangePassword       Boolean  @default(false)
  authVersion              Int      @default(0)
  role                     String   @default("STUDENT")
  school                   String?
  requestedRole            String   @default("STUDENT")
  teacherApplicationStatus String   @default("NOT_REQUIRED")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  submissions              Submission[]
  userRoles                UserRole[]
  classMembers             ClassMember[]
  contestParticipants      ContestParticipant[]
  assignmentStudents       AssignmentStudent[]
  sessions                 UserSession[]
  externalAccounts         ExternalAccount[]
  competitionAwards        CompetitionAward[]
  helperDevices            HelperDevice[]
  remoteTasks              RemoteSubmissionTask[]
  skillProfiles            UserSkillProfile[]
  problemMetrics           UserProblemMetric[]
  learningPlans            LearningPlan[]
  favorites                UserFavorite[]
  wrongBook                UserWrongBook[]
  problemNotes             ProblemNote[]
  recommendationFeedback   RecommendationFeedback[]
  communityPosts           CommunityPost[]
  communityReplies         CommunityReply[]
  communityReactions       CommunityReaction[]
  announcements            Announcement[]
  notifications            Notification[]
  directConversationsAsParticipantOne DirectConversation[] @relation("DirectConversationParticipantOne")
  directConversationsAsParticipantTwo DirectConversation[] @relation("DirectConversationParticipantTwo")
  sentDirectMessages       DirectMessage[]      @relation("DirectMessageSender")
  reportedContent          ContentReport[]          @relation("ContentReportReporter")
  reviewedContentReports   ContentReport[]          @relation("ContentReportReviewer")
  problemFeedbacks         ProblemFeedback[]        @relation("ProblemFeedbackReporter")
  reviewedProblemFeedbacks ProblemFeedback[]        @relation("ProblemFeedbackReviewer")
}

model CompetitionAward {
  id             String   @id @default(cuid())
  userId         String
  competition    String
  year           Int?
  season         String?
  region         String?
  awardLevel     String
  teamName       String?
  rank           Int?
  certificateUrl String?
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([competition, year])
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  permissions Permission[]
  userRoles   UserRole[]
  createdAt   DateTime     @default(now())
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  description String?
  roles       Role[]
  createdAt   DateTime @default(now())
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model UserSession {
  id           String   @id @default(cuid())
  userId       String
  refreshTokenHash String @unique
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([refreshTokenHash])
  @@index([userId])
}

model ExternalAccount {
  id                         String    @id @default(cuid())
  userId                     String
  platform                   String
  remoteUserId               String
  remoteUsername             String?
  status                     String    @default("IDENTITY_ONLY")
  ownershipVerified          Boolean   @default(false)
  helperConnected            Boolean   @default(false)
  remoteLoginVerifiedAt      DateTime?
  lastSuccessfulSubmissionAt DateTime?
  lastFailureAt              DateTime?
  lastFailureReason          String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  user                       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([platform, remoteUserId])
  @@index([userId])
}

model ExternalPlatform {
  id                            String    @id @default(cuid())
  code                          String    @unique
  name                          String
  baseUrl                       String
  enabled                       Boolean   @default(true)
  readOnly                      Boolean   @default(true)
  allowAutoSubmit               Boolean   @default(false)
  requireUserConfirmation       Boolean   @default(true)
  supportsMetadata              Boolean   @default(false)
  supportsStatement             Boolean   @default(false)
  supportsBrowserSubmission     Boolean   @default(false)
  supportsOfficialSubmissionApi Boolean   @default(false)
  supportsOfficialResultApi     Boolean   @default(false)
  allowLiveContestSubmission    Boolean   @default(false)
  adapterVersion                String    @default("0.0.0")
  circuitOpenedAt               DateTime?
  killSwitchReason              String?
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt
}

model HelperDevice {
  id               String   @id @default(cuid())
  userId           String
  deviceName       String
  browserName      String
  extensionVersion String
  publicKey        String   @default("")
  status           String   @default("ONLINE")
  lastSeenAt       DateTime @default(now())
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RemoteSubmissionTask {
  id                     String    @id @default(cuid())
  submissionId           String    @unique
  userId                 String
  platformCode           String
  externalAccountId      String
  remoteProblemId        String
  remoteContestId        String?
  remoteProblemIndex     String?
  language               String
  sourceCode             String
  status                 String    @default("PENDING")
  assignedHelperDeviceId String?
  expiresAt              DateTime
  attemptCount           Int       @default(0)
  maximumAttempts        Int       @default(1)
  remoteSubmissionId     String?
  failureCode            String?
  failureMessage         String?
  nonce                  String?
  signature              String?
  leaseNonce             String?
  leaseExpiresAt         DateTime?
  helperStage            String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([assignedHelperDeviceId])
  @@index([remoteSubmissionId])
  @@index([leaseExpiresAt])
}

// ===================== 题库 =====================

model Problem {
  id             String   @id @default(cuid())
  title          String
  source         String   @default("LOCAL")
  status         String   @default("DRAFT")
  difficulty     String?
  timeLimit      Int      @default(1000)
  memoryLimit    Int      @default(256)
  outputLimit    Int      @default(64)
  allowLanguages String[] @default(["cpp", "c", "python", "java"])
  scoreType      String   @default("SUM")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  versions           ProblemVersion[]
  tags               ProblemTag[]
  permissions        ProblemPermission[]
  submissions        Submission[]
  contestProblems    ContestProblem[]
  assignmentProblems AssignmentProblem[]
  knowledgePoints    ProblemKnowledgePoint[]
  favorites          UserFavorite[]
  wrongBook          UserWrongBook[]
  problemNotes       ProblemNote[]
  problemListItems   ProblemListItem[]
  learningPlanItems  LearningPlanItem[]
  sourceInfo         ProblemSource?
  communityPosts     CommunityPost[]
  feedbacks          ProblemFeedback[]
}

model ProblemSource {
  id                   String    @id @default(cuid())
  problemId            String    @unique
  platform             String
  remoteProblemId      String
  remoteUrl            String?
  remoteContestId      String?
  remoteTaskScreenName String?
  remoteProblemIndex   String?
  metadataHash         String?
  capabilityJson       Json?
  syncStatus           String    @default("IDLE")
  lastSyncAt           DateTime?
  lastErrorCode        String?
  problem              Problem   @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([platform, remoteProblemId])
}

model ProblemVersion {
  id           String            @id @default(cuid())
  problemId    String
  version      Int               @default(1)
  description  String
  inputFormat  String?
  outputFormat String?
  sampleInput  String?
  sampleOutput String?
  hint         String?
  dataRange    String?
  isCurrent    Boolean           @default(true)
  createdAt    DateTime          @default(now())
  problem      Problem           @relation(fields: [problemId], references: [id], onDelete: Cascade)
  submissions  Submission[]
  testGroups   TestGroup[]
  testCases    ProblemTestCase[]
  checker      Checker?

  @@index([problemId])
}

model ProblemTag {
  id        String  @id @default(cuid())
  problemId String
  name      String
  type      String  @default("TAG")
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([problemId])
  @@index([name])
}

model ProblemPermission {
  id         String  @id @default(cuid())
  problemId  String
  targetType String
  targetId   String
  permission String
  problem    Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([problemId])
}

model TestGroup {
  id               String         @id @default(cuid())
  problemVersionId String
  name             String?
  score            Int            @default(10)
  testCount        Int            @default(1)
  order            Int            @default(0)
  problemVersion   ProblemVersion @relation(fields: [problemVersionId], references: [id], onDelete: Cascade)

  @@index([problemVersionId])
}

model Checker {
  id               String         @id @default(cuid())
  problemVersionId String         @unique
  type             String         @default("STANDARD")
  sourceCode       String?
  language         String?
  problemVersion   ProblemVersion @relation(fields: [problemVersionId], references: [id], onDelete: Cascade)
}

model ProblemTestCase {
  id               String         @id @default(cuid())
  problemVersionId String
  input            String         @default("")
  expectedOutput   String         @default("")
  score            Int            @default(10)
  order            Int            @default(0)
  isSample         Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  problemVersion   ProblemVersion @relation(fields: [problemVersionId], references: [id], onDelete: Cascade)

  @@index([problemVersionId])
  @@index([problemVersionId, order])
}

// ===================== 提交与评测 =====================

model Submission {
  id                 String              @id @default(cuid())
  problemId          String
  problemVersionId   String?
  userId             String
  language           String
  sourceCode         String
  status             String              @default("PENDING")
  score              Int                 @default(0)
  timeUsed           Int?
  memoryUsed         Int?
  compileMessage     String?
  createdAt          DateTime            @default(now())
  judgedAt           DateTime?
  problem            Problem             @relation(fields: [problemId], references: [id])
  problemVersion     ProblemVersion?     @relation(fields: [problemVersionId], references: [id])
  user               User                @relation(fields: [userId], references: [id])
  cases              SubmissionCase[]
  judgeTask          JudgeTask?
  remoteJob          RemoteJudgeJob?
  contestSubmissions ContestSubmission[]

  @@index([userId])
  @@index([problemId])
  @@index([status])
  @@index([createdAt])
}

model SubmissionCase {
  id             String     @id @default(cuid())
  submissionId   String
  caseIndex      Int
  status         String     @default("PENDING")
  timeUsed       Int?
  memoryUsed     Int?
  input          String?
  expectedOutput String?
  actualOutput   String?
  submission     Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
}

model JudgeTask {
  id           String     @id @default(cuid())
  submissionId String     @unique
  priority     Int        @default(0)
  retryCount   Int        @default(0)
  maxRetries   Int        @default(3)
  nodeId       String?
  createdAt    DateTime   @default(now())
  startedAt    DateTime?
  finishedAt   DateTime?
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([nodeId])
  @@index([priority])
}

model RemoteJudgeJob {
  id                 String     @id @default(cuid())
  submissionId       String     @unique
  platform           String
  remoteProblemId    String
  remoteSubmissionId String?
  accountId          String?
  queryCount         Int        @default(0)
  maxQueries         Int        @default(60)
  lastQueryAt        DateTime?
  nextQueryAt        DateTime?
  rawStatus          String?
  errorMessage       String?
  createdAt          DateTime   @default(now())
  finishedAt         DateTime?
  submission         Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model JudgeNode {
  id            String    @id @default(cuid())
  name          String
  type          String    @default("LOCAL")
  status        String    @default("ONLINE")
  load          Float     @default(0)
  lastHeartbeat DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model JudgeLanguage {
  id             String   @id @default(cuid())
  code           String   @unique
  name           String
  extension      String
  compileCommand String?
  runCommand     String
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
}

model VerdictMapping {
  id            String @id @default(cuid())
  platform      String
  rawStatus     String
  unifiedStatus String

  @@unique([platform, rawStatus])
}

// ===================== 比赛 =====================

model Contest {
  id             String    @id @default(cuid())
  contestNo      Int       @unique @default(autoincrement())
  title          String
  description    String?
  mode           String    @default("ACM")
  visibility     String    @default("PUBLIC")
  password       String?
  startTime      DateTime
  endTime        DateTime
  registerStart  DateTime?
  registerEnd    DateTime?
  freezeTime     DateTime?
  allowUpsolve   Boolean   @default(true)
  maxSubmissions Int?
  penaltyTime    Int       @default(20)
  teamMode       Boolean   @default(false)
  isRated        Boolean   @default(false)
  createdBy      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  problems     ContestProblem[]
  participants ContestParticipant[]
  submissions  ContestSubmission[]
  ranks        ContestRankSnapshot[]
}

model ContestProblem {
  id        String  @id @default(cuid())
  contestId String
  problemId String
  order     Int     @default(0)
  score     Int     @default(100)
  contest   Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  problem   Problem @relation(fields: [problemId], references: [id])

  @@unique([contestId, problemId])
}

model ContestParticipant {
  id           String    @id @default(cuid())
  contestId    String
  userId       String
  registeredAt DateTime  @default(now())
  isVirtual    Boolean   @default(false)
  virtualStart DateTime?
  virtualEnd   DateTime?
  contest      Contest   @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id])

  @@unique([contestId, userId])
}

model ContestSubmission {
  id           String     @id @default(cuid())
  contestId    String
  submissionId String     @unique
  contest      Contest    @relation(fields: [contestId], references: [id], onDelete: Cascade)
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([contestId])
}

model ContestRankSnapshot {
  id        String   @id @default(cuid())
  contestId String
  rankData  String
  createdAt DateTime @default(now())
  contest   Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@index([contestId])
}

// ===================== 教学模块 =====================

model Organization {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  courses     Course[]
}

model Course {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  classes        Class[]
}

model Class {
  id                String        @id @default(cuid())
  courseId          String?
  name              String
  teacherId         String
  status            String        @default("PENDING")
  reviewNote        String?
  approvedAt        DateTime?
  joinCode          String?       @unique
  joinCodeExpiresAt DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  course            Course?       @relation(fields: [courseId], references: [id], onDelete: SetNull)
  members           ClassMember[]
}

model ClassMember {
  id         String    @id @default(cuid())
  classId    String
  userId     String
  role       String    @default("STUDENT")
  status     String    @default("APPROVED")
  reviewNote String?
  joinedAt   DateTime  @default(now())
  reviewedAt DateTime?
  class      Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id])

  @@unique([classId, userId])
  @@index([classId, status])
  @@index([userId, status])
}

model Assignment {
  id            String              @id @default(cuid())
  classId       String
  title         String
  description   String?
  startTime     DateTime
  endTime       DateTime
  allowLate     Boolean             @default(false)
  latePenalty   Float               @default(0)
  passCondition String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  problems      AssignmentProblem[]
  students      AssignmentStudent[]
}

model AssignmentProblem {
  id           String     @id @default(cuid())
  assignmentId String
  problemId    String
  order        Int        @default(0)
  score        Int        @default(100)
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  problem      Problem    @relation(fields: [problemId], references: [id])

  @@unique([assignmentId, problemId])
}

model AssignmentStudent {
  id           String     @id @default(cuid())
  assignmentId String
  userId       String
  status       String     @default("PENDING")
  score        Int        @default(0)
  submittedAt  DateTime?
  completedAt  DateTime?
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id])

  @@unique([assignmentId, userId])
}

// ===================== 用户偏好 =====================

model UserFavorite {
  id        String   @id @default(cuid())
  userId    String
  problemId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([userId, problemId])
}

model UserWrongBook {
  id            String   @id @default(cuid())
  userId        String
  problemId     String
  errorType     String?
  lastAttemptAt DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem       Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([userId, problemId])
}

model ProblemList {
  id          String            @id @default(cuid())
  name        String
  description String?
  createdBy   String
  isPublic    Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  items       ProblemListItem[]
}

model ProblemListItem {
  id        String      @id @default(cuid())
  listId    String
  problemId String
  order     Int         @default(0)
  createdAt DateTime    @default(now())
  list      ProblemList @relation(fields: [listId], references: [id], onDelete: Cascade)
  problem   Problem     @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([listId, problemId])
  @@index([listId, order])
}

// ===================== 社区与学习服务 =====================

model CommunityPost {
  id           String              @id @default(cuid())
  type         String              @default("DISCUSSION")
  title        String?
  content      String
  category     String?
  spoilerLevel String              @default("NONE")
  status       String              @default("PUBLISHED")
  isPinned     Boolean             @default(false)
  isResolved   Boolean             @default(false)
  viewCount    Int                 @default(0)
  authorId     String
  problemId    String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  author       User                @relation(fields: [authorId], references: [id], onDelete: Cascade)
  problem      Problem?            @relation(fields: [problemId], references: [id], onDelete: SetNull)
  replies      CommunityReply[]
  reactions    CommunityReaction[]

  @@index([type, status, createdAt])
  @@index([problemId, status, createdAt])
  @@index([authorId, createdAt])
}

model CommunityReply {
  id        String        @id @default(cuid())
  postId    String
  authorId  String
  content   String
  status    String        @default("PUBLISHED")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId, status, createdAt])
  @@index([authorId, createdAt])
}

model CommunityReaction {
  id        String        @id @default(cuid())
  userId    String
  postId    String
  type      String        @default("UPVOTE")
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, type])
  @@index([postId, createdAt])
}

model Announcement {
  id        String    @id @default(cuid())
  title     String
  content   String
  audience  String    @default("ALL")
  status    String    @default("PUBLISHED")
  isPinned  Boolean   @default(false)
  publishAt DateTime  @default(now())
  expiresAt DateTime?
  authorId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([audience, status, publishAt])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  content   String?
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

model DirectConversation {
  id               String          @id @default(cuid())
  participantOneId String
  participantTwoId String
  lastMessageAt    DateTime        @default(now())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  participantOne   User            @relation("DirectConversationParticipantOne", fields: [participantOneId], references: [id], onDelete: Cascade)
  participantTwo   User            @relation("DirectConversationParticipantTwo", fields: [participantTwoId], references: [id], onDelete: Cascade)
  messages         DirectMessage[]

  @@unique([participantOneId, participantTwoId])
  @@index([participantOneId, lastMessageAt])
  @@index([participantTwoId, lastMessageAt])
}

model DirectMessage {
  id             String             @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  readAt         DateTime?
  createdAt      DateTime           @default(now())
  conversation   DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User               @relation("DirectMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([conversationId, readAt])
}

model ContentReport {
  id           String   @id @default(cuid())
  reporterId   String
  targetType   String
  targetId     String
  reason       String
  detail       String?
  status       String   @default("OPEN")
  reviewerId   String?
  reviewerNote String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  reporter     User     @relation("ContentReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewer     User?    @relation("ContentReportReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([targetType, targetId])
  @@index([reporterId, createdAt])
}

model ProblemFeedback {
  id           String   @id @default(cuid())
  problemId    String
  reporterId   String
  type         String   @default("STATEMENT")
  content      String
  status       String   @default("OPEN")
  reviewerId   String?
  reviewerNote String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  problem      Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  reporter     User     @relation("ProblemFeedbackReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewer     User?    @relation("ProblemFeedbackReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([problemId, status, createdAt])
  @@index([reporterId, createdAt])
}

// ===================== 能力分析 =====================

model KnowledgePoint {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  parentId    String?
  level       Int      @default(0)
  createdAt   DateTime @default(now())

  children      KnowledgePoint[]        @relation("KnowledgePointHierarchy")
  parent        KnowledgePoint?         @relation("KnowledgePointHierarchy", fields: [parentId], references: [id])
  prerequisites KnowledgeRelation[]     @relation("PrerequisiteTarget")
  requiredBy    KnowledgeRelation[]     @relation("PrerequisiteSource")
  problemLinks  ProblemKnowledgePoint[]
}

model KnowledgeRelation {
  id       String         @id @default(cuid())
  sourceId String
  targetId String
  source   KnowledgePoint @relation("PrerequisiteSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target   KnowledgePoint @relation("PrerequisiteTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId])
}

model ProblemKnowledgePoint {
  id               String         @id @default(cuid())
  problemId        String
  knowledgePointId String
  weight           Float          @default(1.0)
  problem          Problem        @relation(fields: [problemId], references: [id], onDelete: Cascade)
  knowledgePoint   KnowledgePoint @relation(fields: [knowledgePointId], references: [id], onDelete: Cascade)

  @@unique([problemId, knowledgePointId])
}

model UserSkillProfile {
  id               String    @id @default(cuid())
  userId           String
  knowledgePointId String
  score            Float     @default(0)
  totalAttempts    Int       @default(0)
  totalSolved      Int       @default(0)
  lastAttemptAt    DateTime?
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, knowledgePointId])
}

model UserProblemMetric {
  id            String    @id @default(cuid())
  userId        String
  problemId     String
  totalAttempts Int       @default(0)
  totalSolved   Int       @default(0)
  firstSolvedAt DateTime?
  lastAttemptAt DateTime?
  usedHint      Boolean   @default(false)
  timeSpentMin  Int       @default(0)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, problemId])
}

model LearningPlan {
  id          String                @id @default(cuid())
  userId      String
  name        String
  description String?
  type        String                @default("DAILY")
  startDate   DateTime
  endDate     DateTime
  dailyTarget Int                   @default(3)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       LearningPlanItem[]
  checkIns    LearningPlanCheckIn[]
}

model LearningPlanItem {
  id               String       @id @default(cuid())
  planId           String
  problemId        String?
  knowledgePointId String?
  dayIndex         Int          @default(0)
  type             String       @default("PRACTICE")
  completed        Boolean      @default(false)
  plan             LearningPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  problem          Problem?     @relation(fields: [problemId], references: [id], onDelete: SetNull)

  @@index([planId, dayIndex])
}

model LearningPlanCheckIn {
  id        String       @id @default(cuid())
  planId    String
  date      DateTime
  createdAt DateTime     @default(now())
  plan      LearningPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, date])
  @@index([planId])
}

model ProblemNote {
  id             String    @id @default(cuid())
  userId         String
  problemId      String
  content        String
  reviewStatus   String    @default("ACTIVE")
  nextReviewAt   DateTime?
  lastReviewedAt DateTime?
  reviewCount    Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem        Problem   @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([userId, nextReviewAt])
  @@index([userId, problemId])
}

model RecommendationFeedback {
  id                 String   @id @default(cuid())
  userId             String
  problemId          String?
  recommendationType String
  rating             Int
  comment            String?
  createdAt          DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ===================== 系统与审计 =====================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  detail     String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}
